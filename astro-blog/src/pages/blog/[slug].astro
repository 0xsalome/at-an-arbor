---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { buildBacklinksMap, getBacklinksForSlug } from '../../utils/backlinks';

export async function getStaticPaths() {
  // unlisted記事も含めて全て取得（直リンクでアクセス可能にするため）
  const blogEntries = await getCollection('blog');
  const sortedEntries = [...blogEntries].sort((a, b) =>
    (b.data.updated || b.data.date).localeCompare(a.data.updated || a.data.date)
  );

  const backlinksMap = await buildBacklinksMap(blogEntries);

  return sortedEntries.map((entry, index) => {
    const newerEntry = sortedEntries[index - 1];
    const olderEntry = sortedEntries[index + 1];

    return {
      params: { slug: entry.slug },
      props: {
        entry,
        backlinks: getBacklinksForSlug(entry.slug, backlinksMap),
        adjacentPosts: {
          newer: newerEntry ? {
            slug: newerEntry.slug,
            title: newerEntry.data.title,
            updated: newerEntry.data.updated || newerEntry.data.date,
          } : undefined,
          older: olderEntry ? {
            slug: olderEntry.slug,
            title: olderEntry.data.title,
            updated: olderEntry.data.updated || olderEntry.data.date,
          } : undefined,
        },
      },
    };
  });
}

const { entry, backlinks, adjacentPosts } = Astro.props;
const { Content } = await entry.render();
---

<BlogPost
  title={entry.data.title}
  date={entry.data.date}
  updated={entry.data.updated || entry.data.date}
  tags={entry.data.tags}
  backlinks={backlinks}
  versions={entry.data.versions}
  latestLog={entry.data.latestLog}
  noindex={entry.data.noindex}
  adjacentPosts={adjacentPosts}
>
  <Content />
</BlogPost>
